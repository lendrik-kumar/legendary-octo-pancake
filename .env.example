# Copy to server/.env and fill in values.
# Run the API from the server folder: cd server && npm run dev

# Server (Vite dev proxy reads this PORT from server/.env automatically)
PORT=3001
NODE_ENV=development

# Browser origin allowed for CORS + cookies (no trailing slash). Must match your Vite URL (port included).
CLIENT_ORIGIN=http://localhost:5173

# Gate the form: users must enter this key once per browser session
FORM_ACCESS_KEY=replace-with-a-long-random-passphrase

# Signs the session cookie (use openssl rand -hex 32 or similar)
SESSION_SECRET=replace-with-32-plus-byte-random-secret

# Google Sheets — pick ONE credential style:
# A) Drop a service-account *.json in the server/ folder — it is picked up automatically; or set an explicit path (relative to server/):
# GOOGLE_APPLICATION_CREDENTIALS=./keys/service-account.json

# B) Or paste the full service account JSON on a single line (then you can omit GOOGLE_APPLICATION_CREDENTIALS)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....gserviceaccount.com",...}

# Target spreadsheet (from the URL: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit)
SPREADSHEET_ID=Sheet1

# Tab name inside the workbook (create an empty sheet with this name, or use Sheet1)
SHEET_NAME=Submissions

# Share the spreadsheet with the service account email (client_email in the JSON) as Editor.

# Sheet layout: row 1 must be exactly these headers (or leave the tab completely empty — the API writes them once):
# Created At | Team Name | Leader Name | Leader Contact | GitHub | PPT | Deployed | Updated At
